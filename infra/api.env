COMPOSE_PROJECT_NAME=actrade-dev
TZ=Asia/Shanghai

APP_NAME=actrade-api
APP_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=actrade
POSTGRES_USER=actrade
POSTGRES_PASSWORD=actrade123

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=actrade123
REDIS_DATABASE=0
REDIS_TIMEOUT=3s

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673
RABBITMQ_USER=actrade
RABBITMQ_PASSWORD=actrade123
RABBITMQ_VHOST=/

JPA_DDL_AUTO=update
SQL_INIT_MODE=never
SHOW_SQL=false

MANAGEMENT_ENDPOINTS=health,info
MANAGEMENT_HEALTH_DETAILS=always

ALIPAY_APP_ID=2021000148664596
ALIPAY_MERCHANT_PRIVATE_

# 生产时一般才是 openapi.alipay.com
ALIPAY_GATEWAY_HOST=openapi-sandbox.dl.alipaydev.com

# 这两个是你自己系统的地址，不是去支付宝后台抄来的
ALIPAY_NOTIFY_URL=https://laureen-herolike-phylis.ngrok-free.dev/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://laureen-herolike-phylis.ngrok-free.dev/api/payments/alipay/return

# 建议用用户能看懂的品牌名
ALIPAY_SUBJECT_PREFIX=Actrade订单

MINIO_ROOT_USER=actrade
MINIO_ROOT_PASSWORD=actrade123456
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

