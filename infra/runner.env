SERVER_PORT=8089

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USER=actrade
RABBITMQ_PASSWORD=actrade123
RABBITMQ_VHOST=/

RABBITMQ_PREFETCH=1
RABBITMQ_CONCURRENCY=1
RABBITMQ_MAX_CONCURRENCY=1

RUNNER_INSTANCE_ID=runner-node-01
RUNNER_WORKSPACE_ROOT=/home/hesse/dev/activation-runner-workspace
RUNNER_EXECUTION_MODE=docker
RUNNER_TASK_TIMEOUT_SECONDS=300
RUNNER_CLEANUP_ENABLED=true
RUNNER_CLEANUP_EXPIRE_HOURS=24

RUNNER_MQ_EXCHANGE=activation.task.exchange
RUNNER_MQ_QUEUE=activation.task.execute
RUNNER_MQ_ROUTING_KEY=activation.task.execute
RUNNER_MQ_DLX=activation.task.dlx
RUNNER_MQ_DLQ=activation.task.execute.dlq
RUNNER_MQ_DLQ_ROUTING_KEY=activation.task.execute.dlq

ACTRADE_API_BASE_URL=http://localhost:8080
ACTRADE_API_INTERNAL_TOKEN=actrade-internal-token-change-this-in-production-environment
ACTRADE_API_INTERNAL_TOKEN_HEADER=X-Internal-Token
ACTRADE_API_CONNECT_TIMEOUT=5s
ACTRADE_API_READ_TIMEOUT=60s

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ARTIFACTS=activation-artifacts

DOCKER_BINARY=docker
DOCKER_RUNTIME=runsc
DOCKER_NETWORK_DISABLED=true
DOCKER_DEFAULT_TIMEOUT_SECONDS=300
DOCKER_DEFAULT_MEMORY_MB=256
DOCKER_DEFAULT_CPU_LIMIT=1.0
DOCKER_PIDS_LIMIT=128
DOCKER_IMAGE_SHELL=activation-runner-shell:latest